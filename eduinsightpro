                  style={{
                    background: C.surfaceHigh,
                    border: `1px solid ${C.border}`,
                    color: C.subtle,
                    borderRadius: 8,
                    padding: '5px 12px',
                    cursor: 'pointer',
                    fontSize: 12,
                    fontFamily: 'Inter',
                  }}
                >
                  {t}
                </button>
