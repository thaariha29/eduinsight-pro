          </Card>

          {(aiPath || (selectedTopic && LEARNING_PATHS[selectedTopic])) && (
            <Card style={{ maxHeight: 380, overflowY: 'auto' }}>
              <h4
                style={{
                  color: C.accentGlow,
                  fontFamily: 'Space Grotesk',
                  margin: '0 0 16px',
