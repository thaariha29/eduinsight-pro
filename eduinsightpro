                        style={{
                          width: 22,
                          height: 22,
                          borderRadius: '50%',
                          background: C.accent + '33',
                          color: C.accent,
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center',
                          fontSize: 11,
                          fontFamily: 'JetBrains Mono',
                          fontWeight: 700,
                          flexShrink: 0,
                        }}
                      >
                        {i + 1}
                      </div>
                      <div
                        style={{
                          color: C.text,
                          fontFamily: 'Inter',
                          fontSize: 14,
                        }}
                      >
                        {s}
                      </div>
