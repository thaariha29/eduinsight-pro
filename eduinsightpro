          <Card>
            <h4
              style={{
                color: C.text,
                fontFamily: 'Space Grotesk',
                margin: '0 0 12px',
              }}
            >
              ⚡ Quick Quiz
            </h4>
            <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
              {Object.keys(QUIZ_BANK).map((t) => (
                <button
                  key={t}
                  onClick={() => startQuiz(t)}
                  style={{
                    background: C.surfaceHigh,
                    border: `1px solid ${C.border}`,
                    color: C.subtle,
                    borderRadius: 8,
                    padding: '8px 14px',
                    cursor: 'pointer',
                    fontFamily: 'Inter',
                    fontSize: 13,
                  }}
                >
